FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_API_URL=
ARG VITE_LOGIN_HOME_URL=/
ARG VITE_BASE_PATH=/escritorio/
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_LOGIN_HOME_URL=$VITE_LOGIN_HOME_URL
ENV VITE_BASE_PATH=$VITE_BASE_PATH

RUN npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
